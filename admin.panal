<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>GlowCart Admin Panel</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<!-- Firebase -->
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-database.js"></script>

<style>
body {
  font-family: Arial;
  margin: 0;
  background: #f1f1f1;
}

header {
  background: #111;
  color: white;
  padding: 15px;
  text-align: center;
  font-size: 20px;
}

.container {
  padding: 15px;
}

input {
  width: 100%;
  padding: 10px;
  margin: 5px 0;
}

button {
  padding: 10px;
  margin-top: 5px;
  width: 100%;
  border: none;
  background: green;
  color: white;
}

.card {
  background: white;
  padding: 10px;
  margin-top: 10px;
  border-radius: 10px;
}

.deleteBtn {
  background: red;
}
</style>
</head>

<body>

<header>🧑‍💼 GlowCart Admin Panel</header>

<div class="container">

  <h3>Add Product</h3>
  <input id="name" placeholder="Product Name">
  <input id="price" placeholder="Price">
  <input id="img" placeholder="Image URL">
  <button onclick="addProduct()">Add Product</button>

  <h3>All Products</h3>
  <div id="productList"></div>

</div>

<script>
// 🔥 Tumhara Firebase config
const firebaseConfig = {
  apiKey: "AIzaSyCole_pSUeJV9Fij8UBKALiZXlhPLsMdZ8",
  authDomain: "glowcart-dac7d.firebaseapp.com",
  databaseURL: "https://glowcart-dac7d-default-rtdb.firebaseio.com/",
  projectId: "glowcart-dac7d",
  storageBucket: "glowcart-dac7d.firebasestorage.app",
  messagingSenderId: "609791967645",
  appId: "1:609791967645:web:56538a5969670675d1ef74"
};

firebase.initializeApp(firebaseConfig);
const db = firebase.database();

// ➕ Add Product
function addProduct(){
  let name = document.getElementById("name").value;
  let price = document.getElementById("price").value;
  let img = document.getElementById("img").value;

  if(name=="" || price=="" || img==""){
    alert("Fill all fields");
    return;
  }

  let product = { name, price, img };

  db.ref("products").push(product);
  alert("Product Added!");

  document.getElementById("name").value="";
  document.getElementById("price").value="";
  document.getElementById("img").value="";
}

// 📦 Load Products
function loadProducts(){
  db.ref("products").on("value", snapshot => {
    let data = snapshot.val();
    let html = "";

    for(let key in data){
      let p = data[key];

      html += `
      <div class="card">
        <img src="${p.img}" width="100"><br>
        <b>${p.name}</b><br>
        ₹${p.price}<br><br>
        <button class="deleteBtn" onclick="deleteProduct('${key}')">Delete</button>
      </div>`;
    }

    document.getElementById("productList").innerHTML = html;
  });
}

// ❌ Delete Product
function deleteProduct(id){
  db.ref("products/" + id).remove();
  alert("Deleted!");
}

// Init
loadProducts();
</script>

</body>
</html>
